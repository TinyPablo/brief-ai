# Copy this file to .env and fill in the values:
#   cp .env.example .env

# Anthropic API key — https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Google AI Studio API key — https://aistudio.google.com/apikey
GEMINI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx

# 6-digit PIN used to log in
APP_PIN=000000

# Secret used to sign session cookies. Use a long random string, e.g.:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string

# Set to false only for local http testing (cookies otherwise require https)
COOKIE_SECURE=true

# PostgreSQL credentials (used by both the db container and the backend)
POSTGRES_USER=briefai
POSTGRES_PASSWORD=change-me
POSTGRES_DB=briefai
